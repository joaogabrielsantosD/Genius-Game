TITLE "Top level Entity";
CONSTANT max_cnt = 10;
CONSTANT n = CEIL(LOG2(max_cnt));

SUBDESIGN top
(
	clk, load, ena, clr, d[n..0] : INPUT;
	q[n..0], tc                  : OUTPUT;
)
VARIABLE
	cnt[n..0] : DFF;
	aux: NODE;
BEGIN
	DEFAULTS
		q[] = 0; tc = GND;
	END DEFAULTS;
	cnt[].clk = clk;
	cnt[].clrn = !clr;
	IF load == VCC THEN cnt[].d = d[];
	ELSIF () THEN
		aux = VCC;
		cnt[].d = 0;
	ELSE cnt[n..0].d = cnt[n..0].q;
	END IF;
	tc = aux;
	q[] = cnt[];
END;